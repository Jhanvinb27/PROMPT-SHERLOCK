#############################################
# Prompt Detective Environment Configuration #
#############################################

# Core API Keys
GROQ_API_KEY=

# Stripe (future integration)
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# App Environment
APP_ENV=development
LOG_LEVEL=info
SESSION_SECRET=

# Database (SQLite default)
DATABASE_URL=sqlite:///app_data.sqlite3

# Feature Flags
ENABLE_USAGE_ANALYTICS=true
ENABLE_LEGACY_FALLBACK=true
SHOW_EXPERIMENTAL_PARAMS=false
ENABLE_ONBOARDING_TOOLTIPS=true
FORCE_LEGACY_UI=false

# Security / Sessions
SESSION_TTL_MIN=720

# Optional telemetry / diagnostics
ENABLE_DEBUG_TOOLBAR=false
