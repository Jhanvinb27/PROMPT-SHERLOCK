# =====================================================
# Prompt Detective v2 - Backend Environment Variables
# Copy this to .env and fill in your actual values
# =====================================================

# ---------------------------
# Security (REQUIRED)
# ---------------------------
SECRET_KEY=your-super-secret-key-change-this-in-production-make-it-long-and-random
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=24
REFRESH_TOKEN_EXPIRE_DAYS=30

# ---------------------------
# Database (REQUIRED)
# ---------------------------
# Local development (SQLite):
DATABASE_URL=sqlite:///./app_data.sqlite3

# Production (NeonDB pooled connection - recommended):
# DATABASE_URL_PRODUCTION=postgresql://<user>:<password>@<project>-pooler.neon.tech/<database>?sslmode=require&channel_binding=require
# DB_SSL_MODE=require
# DB_POOL_ENABLED=true
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=0
# DB_POOL_TIMEOUT=30
# DB_POOL_RECYCLE=300
# DB_PRE_PING=true
# DB_STATEMENT_TIMEOUT_MS=30000
# DB_CONNECT_RETRIES=5
# DB_RETRY_INITIAL_DELAY=1.5
# DB_RETRY_BACKOFF_FACTOR=2.0

# ---------------------------
# AI Analysis (REQUIRED)
# ---------------------------
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ---------------------------
# File Storage (REQUIRED)
# ---------------------------
UPLOAD_DIR=./uploads_local
MAX_UPLOAD_SIZE=104857600
PUBLIC_API_BASE_URL=http://localhost:8000

# Cloudinary (OPTIONAL - for production cloud storage)
# Leave blank to use local storage
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---------------------------
# Email Service (REQUIRED for OTP verification)
# ---------------------------
# ⭐ RECOMMENDED: Brevo (Sendinblue) API - FREE 300 emails/day, NO domain verification!
# Perfect for production on Render free tier. Setup guide:
# 1. Sign up FREE at https://app.brevo.com
# 2. Go to Settings → API Keys → "Create a new API key"
# 3. Copy the key and paste below
# 4. Works with ANY email address (gmail, yahoo, etc.) - no domain ownership needed!
BREVO_API_KEY=your_brevo_api_key_here

# Option 2: Resend API (Alternative - requires domain verification)
# Get free API key at: https://resend.com (100 emails/day free)
# ⚠️ Requires domain ownership - won't work with gmail.com or free domains
RESEND_API_KEY=re_your_resend_api_key_here

# Option 3: Gmail SMTP (Fallback - may not work on some platforms)
# ⚠️ SMTP port 587 is blocked on Render free tier and some other platforms
# Setup guide: https://support.google.com/accounts/answer/185833
EMAIL_PROVIDER=gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-gmail-address@gmail.com
SMTP_PASSWORD=your-gmail-app-password-here
SMTP_USE_TLS=true
EMAIL_FROM_ADDRESS=your-gmail-address@gmail.com
EMAIL_FROM_NAME=Your App Name

# ---------------------------
# OAuth (OPTIONAL - for Google Sign-In)
# ---------------------------
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# ---------------------------
# Application Settings
# ---------------------------
DEBUG=true
ENVIRONMENT=development
RATE_LIMIT_PER_MINUTE=60

# Frontend URL (for email links and OAuth redirects)
FRONTEND_URL=http://localhost:3000

# ---------------------------
# CORS Settings
# ---------------------------
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000