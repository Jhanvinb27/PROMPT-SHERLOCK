# =====================================================
# Prompt Detective v2 - Backend Environment Variables
# Copy this to .env and fill in your actual values
# =====================================================

# ---------------------------
# Security (REQUIRED)
# ---------------------------
SECRET_KEY=your-super-secret-key-change-this-in-production-make-it-long-and-random
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=24
REFRESH_TOKEN_EXPIRE_DAYS=30

# ---------------------------
# Database (REQUIRED)
# ---------------------------
# Local development: Use SQLite
DATABASE_URL=sqlite:///./app_data.sqlite3
# Production: Use PostgreSQL
# DATABASE_URL=postgresql://username:password@localhost:5432/prompt_detective

# ---------------------------
# AI Analysis (REQUIRED)
# ---------------------------
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=meta-llama/llama-4-maverick-17b-128e-instruct

# ---------------------------
# File Storage (REQUIRED)
# ---------------------------
UPLOAD_DIR=./uploads_local
MAX_UPLOAD_SIZE=104857600
PUBLIC_API_BASE_URL=http://localhost:8000

# Cloudinary (OPTIONAL - for production cloud storage)
# Leave blank to use local storage
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---------------------------
# Email Service (REQUIRED for OTP verification)
# ---------------------------
# Option 1: Resend API (RECOMMENDED - works on all platforms including Render)
# Get free API key at: https://resend.com (100 emails/day free)
RESEND_API_KEY=re_your_resend_api_key_here

# Option 2: Gmail SMTP (Fallback - may not work on some free tiers due to port blocking)
# Setup guide: https://support.google.com/accounts/answer/185833
EMAIL_PROVIDER=gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-gmail-address@gmail.com
SMTP_PASSWORD=your-gmail-app-password-here
SMTP_USE_TLS=true
EMAIL_FROM_ADDRESS=your-gmail-address@gmail.com
EMAIL_FROM_NAME=Your App Name

# ---------------------------
# OAuth (OPTIONAL - for Google Sign-In)
# ---------------------------
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# ---------------------------
# Application Settings
# ---------------------------
DEBUG=true
ENVIRONMENT=development
RATE_LIMIT_PER_MINUTE=60

# Frontend URL (for email links and OAuth redirects)
FRONTEND_URL=http://localhost:3000

# ---------------------------
# CORS Settings
# ---------------------------
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000