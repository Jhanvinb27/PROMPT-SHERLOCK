# =====================================================
# Prompt Detective v2 - Frontend Environment Variables
# Copy this to .env and fill in your actual values
# =====================================================

# ---------------------------
# Backend API URL (REQUIRED)
# ---------------------------
# Local development
VITE_API_URL=http://localhost:8000/api/v1
# Production
# VITE_API_URL=https://your-backend-domain.com/api/v1

# ---------------------------
# Application Title
# ---------------------------
VITE_APP_TITLE=Prompt Detective

# ---------------------------
# Google OAuth Client ID (OPTIONAL)
# ---------------------------
# Same for dev and production
# Get from: https://console.cloud.google.com/
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id

# Optional explicit redirect URI (defaults to current origin)
# Must be one of the authorized redirect URIs configured in Google Cloud
# Example: https://prompt-detective.vercel.app
VITE_GOOGLE_REDIRECT_URI=